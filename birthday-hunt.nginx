server {
    listen 80;
    server_name birthday.klaudusia.com;  # stable subdomain on klaudusia.com (Hetzner VPS 178.105.76.81)

    location / {
        include proxy_params;
        proxy_pass http://unix:/opt/birthday-hunt/birthday-hunt.sock;
    }

    location /static {
        alias /opt/birthday-hunt/static;
    }

    location /uploads {
        alias /opt/birthday-hunt/uploads;
    }

    location /qr-codes-v2 {
        alias /opt/birthday-hunt/qr-codes-v2;
    }
}